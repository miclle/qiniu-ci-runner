server:
  http_addr: ":25500"
  read_timeout_seconds: 15
  write_timeout_seconds: 60
  idle_timeout_seconds: 120

database:
  backend: sqlite
  # Relative sqlite paths are resolved from the directory containing runnerd.yaml.
  dsn: ./var/runnerd.db
  # Postgres example:
  # backend: postgres
  # dsn: postgres://runner:secret@postgres.example:5432/runnerd?sslmode=require
  # MySQL example:
  # backend: mysql
  # dsn: runner:secret@tcp(mysql.example:3306)/runnerd?parseTime=true&charset=utf8mb4&loc=UTC

auth:
  # Generate with: openssl rand -base64 32
  session_secret: change-me-to-a-random-session-secret
  # Generate with: openssl rand -base64 32
  encryption_key: change-me-to-a-separate-random-encryption-key
  session_ttl_hours: 12

sandbox:
  timeout_seconds: 3600
  create_timeout_seconds: 120
  stop_timeout_seconds: 30

github:
  webhook_secret: change-me
  # GitHub.com only. GitHub Enterprise Server is not currently supported.
  # Webhook requests use repository.full_name from GitHub and are admitted by runner_policies.
  app:
    id: 123456
    # Optional. Enables the ordinary-user UI to link to the GitHub App installation flow.
    # Configure the GitHub App Setup URL as:
    #   http://127.0.0.1:25500/github-app/setup
    slug: your-github-app-slug
    # Optional. Leave empty to resolve the GitHub App installation dynamically per repository.
    # installation_id: 12345678
    # Relative paths are resolved from the directory containing runnerd.yaml.
    private_key_file: ./secrets/github-app.pem
  # Admin-console login uses the same GitHub App's OAuth settings.
  # Configure the GitHub App callback URL as:
  #   http://127.0.0.1:25500/auth/github/callback
  # or the public HTTPS URL used by your deployment.
  oauth:
    client_id: Iv1.your-github-app-client-id
    client_secret: your-github-app-client-secret
    # Optional when runnerd can infer the public URL from the request.
    redirect_url: https://runner.example.com/auth/github/callback
  # Optional repository allowlist. Empty means all repositories that installed the App are allowed.
  # allowed_repositories:
  #   - your-org/*
  #   - your-org/specific-repo
  # Auth alternatives: configure exactly one of app, token, or basic_auth.
  # token: ghp_your-token
  # basic_auth:
  #   username: your-username
  #   password: your-token-or-password

worker:
  max_concurrent_runners: 100
  runner_idle_timeout_seconds: 300
  recovery_timeout_seconds: 120
  lease_ttl_seconds: 300
  retry_base_delay_seconds: 15
  retry_max_delay_seconds: 300
  retry_max_attempts: 5

# Runner specs, runner groups, and runner policies are managed through the
# admin API/UI. Create specs with meaningful names, for example "ubuntu-24-04",
# and set template_id to the E2B template that contains the GitHub runner image.
