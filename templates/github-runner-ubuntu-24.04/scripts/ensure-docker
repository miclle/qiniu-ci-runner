#!/usr/bin/env bash
set -euo pipefail

if ! command -v docker >/dev/null 2>&1 || ! command -v dockerd >/dev/null 2>&1; then
  exit 0
fi

run_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
    return
  fi
  sudo "$@"
}

docker_ready() {
  docker info >/dev/null 2>&1 || run_root docker info >/dev/null 2>&1
}

fix_docker_socket() {
  if [ ! -S /var/run/docker.sock ]; then
    return
  fi
  run_root chgrp docker /var/run/docker.sock 2>/dev/null || true
  run_root chmod 0666 /var/run/docker.sock 2>/dev/null || true
}

if docker_ready; then
  fix_docker_socket
  exit 0
fi

run_root mkdir -p /var/lib/docker /var/run
if [ -f /var/run/docker.pid ]; then
  pid="$(run_root cat /var/run/docker.pid 2>/dev/null || true)"
  if [ -n "$pid" ] && run_root kill -0 "$pid" 2>/dev/null; then
    :
  else
    run_root rm -f /var/run/docker.pid
    run_root nohup dockerd --host=unix:///var/run/docker.sock >/tmp/dockerd.log 2>&1 &
  fi
else
  run_root nohup dockerd --host=unix:///var/run/docker.sock >/tmp/dockerd.log 2>&1 &
fi

for _ in $(seq 1 30); do
  if docker_ready; then
    fix_docker_socket
    exit 0
  fi
  sleep 1
done

echo "dockerd did not become ready; Docker jobs may fail" >&2
tail -n 80 /tmp/dockerd.log >&2 || true
exit 0
